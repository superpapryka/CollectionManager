<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CollectionManager.Views.CollectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Collection">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label
                x:Name="CollectionNameLabel"
                FontSize="26"
                FontAttributes="Bold" />

            <Label
                x:Name="DescriptionLabel"
                FontSize="13" />

            <Label
                x:Name="CountLabel"
                FontSize="12"
                TextColor="Gray" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <Button Text="Add Item" Clicked="AddItem_Clicked" Grid.Row="0" Grid.Column="0" />
                <Button Text="Edit Selected" Clicked="EditItem_Clicked" Grid.Row="0" Grid.Column="1" />
                <Button Text="Delete Selected" Clicked="DeleteItem_Clicked" Grid.Row="1" Grid.Column="0" />
                <Button Text="Summary" Clicked="Summary_Clicked" Grid.Row="1" Grid.Column="1" />
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="Export" Clicked="Export_Clicked" Grid.Column="0" />
                <Button Text="Import" Clicked="Import_Clicked" Grid.Column="1" />
            </Grid>
            <Button Text="Delete Collection" Clicked="DeleteCollection_Clicked" Grid.ColumnSpan="2"/>

            <CollectionView
                x:Name="ItemsView"
                SelectionMode="Single"
                SelectionChanged="ItemsView_SelectionChanged">

                <CollectionView.EmptyView>
                    <Label
                        Text="No items in this collection."
                        HorizontalOptions="Center"
                        Margin="20" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
            Margin="0,0,0,10"
            Padding="12"
            CornerRadius="14"
            HasShadow="True"
            BackgroundColor="White"
            BorderColor="#E0E0E0">

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="White" />
                                                <Setter Property="BorderColor" Value="#E0E0E0" />
                                            </VisualState.Setters>
                                        </VisualState>

                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="#D0E8FF" />
                                                <Setter Property="BorderColor" Value="#2D7FF9" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>

                            <Grid ColumnDefinitions="Auto,80,*" ColumnSpacing="10">
                                <Label
                    Text="✓"
                    FontSize="20"
                    FontAttributes="Bold"
                    TextColor="#2D7FF9"
                    VerticalOptions="Center"
                    Opacity="0" />

                                <Image
                    Grid.Column="1"
                    Source="{Binding ImagePath}"
                    HeightRequest="70"
                    WidthRequest="70"
                    Aspect="AspectFill" />

                                <VerticalStackLayout Grid.Column="2" Spacing="3">
                                    <Label
                        Text="{Binding Name}"
                        FontSize="18"
                        FontAttributes="Bold" />

                                    <Label
                        Text="{Binding Category}"
                        FontSize="12" />

                                    <Label
                        Text="{Binding Quantity, StringFormat='Quantity: {0}'}"
                        FontSize="12" />

                                    <Label
                        Text="{Binding Status, StringFormat='Status: {0}'}"
                        FontSize="12" />

                                    <Label
                        Text="{Binding Notes}"
                        FontSize="12"
                        LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>